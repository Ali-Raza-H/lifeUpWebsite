# Core app
SECRET_KEY=replace-this
LIFEUP_DATABASE=lifeup.db
APP_VERSION=1.0.0
PORT=5000

# Login
AUTH_USERNAME=admin
AUTH_PASSWORD=replace-this
GUEST_AUTH_USERNAME=guest
GUEST_AUTH_PASSWORD=replace-this
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_DAYS=14

# LinkedIn draft email delivery
LINKEDIN_EMAIL_TO=khadamalihussain@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-sender@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-sender@gmail.com
SMTP_USE_TLS=1

# LinkedIn draft LLM generation
LINKEDIN_GENERATION_MODE=server
GEMINI_ENABLED=1
GEMINI_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
JOURNAL_FEEDBACK_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=45
